# ============================================================================
# 8C Auto-Qualification Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HubSpot (required)
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-your-token
HUBSPOT_PORTAL_ID=your-portal-id

# Anthropic (required for LLM analysis)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# User context (for Supabase created_by field)
USER_EMAIL=your@oversecured.com

# Optional: RAG context limits
8C_RAG_MAX_DEAL_CALLS=10
8C_RAG_MAX_COMPANY_CALLS=5
8C_RAG_MAX_CONTACT_CALLS=5
8C_RAG_MAX_CONTEXT_TOKENS=500000

# Optional: Queue processor settings
8C_QUEUE_PROCESSING_INTERVAL_MINUTES=5

# Optional: Slack notifications
SLACK_SALES_CHANNEL_ID=C123456789

# Optional: HubSpot custom properties prefix (if you used custom naming)
HUBSPOT_8C_PROPERTIES_PREFIX=8c_
